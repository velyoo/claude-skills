{
  "name": "Translate UI",
  "identifier": "com.inshot.translate-ui",
  "version": "1.0",
  "description": "切换语言预览 / 汉化 / 还原英文（豆包 API）",
  "compatibleVersion": "70",
  "commands": [
    {
      "name": "汉化选中画板",
      "identifier": "translate",
      "script": "translate.js",
      "handler": "onRun",
      "shortcut": "ctrl shift t"
    },
    {
      "name": "切换语言预览…",
      "identifier": "stress-test",
      "script": "translate.js",
      "handler": "onStressTest",
      "shortcut": "ctrl shift l"
    },
    {
      "name": "还原英文",
      "identifier": "restore-english",
      "script": "translate.js",
      "handler": "onRestoreEnglish"
    },
    {
      "name": "重置 API 配置",
      "identifier": "reset-config",
      "script": "translate.js",
      "handler": "onResetConfig"
    },
    {
      "name": "显示面板",
      "identifier": "show-panel",
      "script": "translate.js",
      "handler": "onShowPanel"
    }
  ],
  "menu": {
    "title": "Translate UI",
    "items": ["show-panel", "-", "stress-test", "translate", "restore-english", "-", "reset-config"]
  }
}
