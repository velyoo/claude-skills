{
  "name": "Translate UI",
  "identifier": "com.inshot.translate-ui",
  "version": "1.2",
  "description": "一键汉化 / 多语言压测 / 图层自动命名（豆包 API）",
  "compatibleVersion": "70",
  "commands": [
    {
      "name": "汉化选中画板",
      "identifier": "translate",
      "script": "translate.js",
      "handler": "onRun",
      "shortcut": "ctrl shift t"
    },
    {
      "name": "多语言适配压测…",
      "identifier": "stress-test",
      "script": "translate.js",
      "handler": "onStressTest",
      "shortcut": "ctrl shift l"
    },
    {
      "name": "图层自动命名",
      "identifier": "rename-layers",
      "script": "translate.js",
      "handler": "onRenameLayer"
    },
    {
      "name": "重置 API 配置",
      "identifier": "reset-config",
      "script": "translate.js",
      "handler": "onResetConfig"
    }
  ],
  "menu": {
    "title": "Translate UI",
    "items": ["translate", "stress-test", "rename-layers", "-", "reset-config"]
  }
}
